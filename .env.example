# =============================================
# RailPass 환경변수 설정 파일
# .env.example을 복사하여 .env로 저장 후 값을 채우세요
# =============================================

# --- 서버 설정 ---
ENVIRONMENT=production          # development | production
SECRET_KEY=your-super-secret-key-change-this-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-for-aes

# --- 데이터베이스 ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=railpass
POSTGRES_USER=railpass_user
POSTGRES_PASSWORD=railpass_password
DATABASE_URL=postgresql+asyncpg://railpass_user:railpass_password@postgres:5432/railpass

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- JWT 설정 ---
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- 프론트엔드 ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- CORS 허용 오리진 (콤마 구분) ---
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
